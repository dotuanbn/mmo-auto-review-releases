{
    "compilerOptions": {
        "target": "ES2020",
        "useDefineForClassFields": true,
        "lib": [
            "ES2020",
            "DOM",
            "DOM.Iterable"
        ],
        "module": "ESNext",
        "skipLibCheck": true,
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,
        "jsx": "react-jsx",
        "strict": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "noFallthroughCasesInSwitch": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/renderer/src/*"
            ],
            "@main/*": [
                "src/main/*"
            ],
            "@shared/*": [
                "src/shared/*"
            ]
        }
    },
    "include": [
        "src/renderer/src",
        "src/preload/index.ts",
        "src/shared"
    ],
    "exclude": [
        "dist",
        "dist-electron",
        "release",
        "release-fix",
        "release-fix2",
        "release-fix3",
        "release-fix4",
        "output",
        "node_modules"
    ],
    "references": []
}
